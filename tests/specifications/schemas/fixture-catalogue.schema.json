{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://github.com/anirbanbasu/bibtera/tests/specifications/schemas/fixture-catalogue.schema.json",
    "title": "Fixture Catalogue",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "$schema",
        "version",
        "description",
        "fixtures"
    ],
    "properties": {
        "$schema": {
            "type": "string"
        },
        "version": {
            "type": "string",
            "minLength": 1
        },
        "description": {
            "type": "string",
            "minLength": 1
        },
        "fixtures": {
            "type": "object",
            "minProperties": 1,
            "propertyNames": {
                "pattern": "^[a-z0-9_]+$"
            },
            "additionalProperties": {
                "$ref": "#/$defs/fixture"
            }
        }
    },
    "$defs": {
        "fixture": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "kind",
                "purpose"
            ],
            "properties": {
                "kind": {
                    "type": "string",
                    "enum": [
                        "file",
                        "inline-data",
                        "virtual-fixture",
                        "generated-state",
                        "derived-expectation",
                        "selection-rule"
                    ]
                },
                "path": {
                    "type": "string",
                    "minLength": 1
                },
                "purpose": {
                    "type": "string",
                    "minLength": 1
                }
            },
            "allOf": [
                {
                    "if": {
                        "properties": {
                            "kind": {
                                "const": "file"
                            }
                        }
                    },
                    "then": {
                        "required": [
                            "path"
                        ]
                    }
                }
            ]
        }
    }
}
