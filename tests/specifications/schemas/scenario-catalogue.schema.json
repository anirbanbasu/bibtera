{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://github.com/anirbanbasu/bibtera/tests/specifications/schemas/scenario-catalogue.schema.json",
    "title": "Scenario Catalogue",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "$schema",
        "version",
        "scope",
        "description",
        "required_fields",
        "scenarios"
    ],
    "properties": {
        "$schema": {
            "type": "string"
        },
        "version": {
            "type": "string",
            "minLength": 1
        },
        "scope": {
            "type": "string",
            "enum": [
                "integration",
                "end-to-end"
            ]
        },
        "description": {
            "type": "string",
            "minLength": 1
        },
        "required_fields": {
            "type": "array",
            "items": {
                "type": "string",
                "minLength": 1
            },
            "uniqueItems": true,
            "minItems": 5
        },
        "scenarios": {
            "type": "array",
            "minItems": 1,
            "items": {
                "$ref": "#/$defs/scenario"
            }
        }
    },
    "allOf": [
        {
            "if": {
                "properties": {
                    "scope": {
                        "const": "end-to-end"
                    }
                }
            },
            "then": {
                "properties": {
                    "required_fields": {
                        "contains": {
                            "const": "command"
                        }
                    },
                    "scenarios": {
                        "items": {
                            "$ref": "#/$defs/end_to_end_scenario"
                        }
                    }
                }
            }
        }
    ],
    "$defs": {
        "scenario": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "id",
                "objective",
                "requirements",
                "fixtures",
                "expected_outcomes"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "pattern": "^(IT|E2E)-[A-Z0-9-]+$"
                },
                "objective": {
                    "type": "string",
                    "minLength": 1
                },
                "requirements": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "pattern": "^[0-9]+(\\.[0-9]+)*$"
                    },
                    "uniqueItems": true,
                    "minItems": 1
                },
                "fixtures": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "pattern": "^[a-z0-9_]+$"
                    },
                    "uniqueItems": true
                },
                "expected_outcomes": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "minLength": 1
                    },
                    "minItems": 1
                },
                "command": {
                    "type": "string",
                    "minLength": 1
                }
            }
        },
        "end_to_end_scenario": {
            "allOf": [
                {
                    "$ref": "#/$defs/scenario"
                },
                {
                    "required": [
                        "command"
                    ]
                }
            ]
        }
    }
}
